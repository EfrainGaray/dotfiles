# Supports: linux/amd64, linux/arm64
# PhantomRelay SaaS — Web (Astro + React SSR)
# Multi-stage build: builder -> runner

# --- Builder ---
FROM node:20-alpine AS builder

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Copy workspace config first for layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/

RUN pnpm install --frozen-lockfile

# Copy source
COPY apps/web/ apps/web/
COPY packages/shared/ packages/shared/
COPY tsconfig.base.json ./

RUN pnpm --filter web build

# Prune to production-only deps
RUN pnpm --filter web --prod deploy /app/prod-deploy

# --- Runner ---
FROM node:20-alpine AS runner

RUN addgroup -S app && adduser -S app -G app

WORKDIR /app

# Copy built output and production dependencies with correct ownership
COPY --from=builder --chown=app:app /app/prod-deploy/node_modules apps/web/node_modules/
COPY --from=builder --chown=app:app /app/apps/web/dist apps/web/dist/
COPY --from=builder --chown=app:app /app/apps/web/package.json apps/web/
COPY --from=builder --chown=app:app /app/packages/shared/ packages/shared/

USER app

EXPOSE 4321

CMD ["node", "apps/web/dist/server/entry.mjs"]
