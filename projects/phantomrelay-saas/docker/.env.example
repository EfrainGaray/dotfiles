# PhantomRelay SaaS — Docker environment variables
# Copy this file to .env and adjust values as needed

# PostgreSQL
POSTGRES_USER=phantom
POSTGRES_PASSWORD=phantom_dev
POSTGRES_DB=phantomrelay

# API
DATABASE_URL=postgresql://phantom:phantom_dev@postgres:5432/phantomrelay
JWT_SECRET=dev-secret-change-in-production
REDIS_URL=redis://redis:6379
RELAY_API_URL=http://host.docker.internal:3000
PORT=3001

# Web
PUBLIC_API_URL=http://localhost:3001
