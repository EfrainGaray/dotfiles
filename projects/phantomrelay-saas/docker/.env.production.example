# PhantomRelay SaaS — Production environment variables
# Copy to .env.production and fill in real values

# --- Postgres ---
POSTGRES_USER=phantom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=phantomrelay

# --- Database ---
# Connection string for NestJS/Prisma
DATABASE_URL=postgresql://phantom:CHANGE_ME_STRONG_PASSWORD@postgres:5432/phantomrelay

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_DIFFERENT

# --- PhantomRelay Engine ---
# URL of the PhantomRelay scraping engine instance
RELAY_API_URL=https://your-phantomrelay-engine.example.com
RELAY_API_KEY=CHANGE_ME_RELAY_KEY

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# --- Frontend ---
# Production domain (no trailing slash)
FRONTEND_URL=https://app.phantomrelay.com
PUBLIC_API_URL=https://api.phantomrelay.com

# --- Docker image config ---
GHCR_OWNER=your-github-org
API_IMAGE_TAG=latest
WEB_IMAGE_TAG=latest

# --- Runtime ---
NODE_ENV=production
