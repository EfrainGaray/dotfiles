---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@/i18n/translations";
import "@/styles/globals.css";

const locale = getLocaleFromUrl(Astro.url);
const isEs = locale === "es";
---

<BaseLayout title={isEs ? "Acceso denegado" : "Forbidden"}>
  <div class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
    <p class="text-7xl font-bold tracking-tight text-warning/30">403</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">
      {isEs ? "Acceso denegado" : "Access denied"}
    </h1>
    <p class="mt-2 text-sm text-muted-foreground max-w-md">
      {isEs
        ? "No tienes permisos para acceder a este recurso. Si crees que es un error, contacta al administrador."
        : "You don't have permission to access this resource. If you think this is a mistake, contact your administrator."}
    </p>
    <div class="mt-6 flex gap-3">
      <a
        href={isEs ? "/es/login" : "/login"}
        class="flex h-8 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        {isEs ? "Iniciar sesión" : "Sign in"}
      </a>
      <a
        href={isEs ? "/es/" : "/"}
        class="flex h-8 items-center rounded-md border border-border px-4 text-sm font-medium transition-colors hover:bg-accent"
      >
        {isEs ? "Ir al inicio" : "Go home"}
      </a>
    </div>
  </div>
</BaseLayout>
