---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t, getLocaleFromUrl, getLocalizedPath, type Locale } from "@/i18n/translations";
import "@/styles/globals.css";

const locale = getLocaleFromUrl(Astro.url);
const l = (key: Parameters<typeof t>[1]) => t(locale, key);
const lp = (path: string) => getLocalizedPath(path, locale);
const otherLocale: Locale = locale === "en" ? "es" : "en";
---

<BaseLayout title="PhantomRelay">
  {/* Nav */}
  <nav class="flex h-12 items-center justify-between border-b border-border px-6">
    <span class="text-sm font-semibold tracking-tight">
      Phantom<span class="text-primary">Relay</span>
    </span>
    <div class="flex items-center gap-3">
      <a
        href={getLocalizedPath("/", otherLocale)}
        class="flex h-7 items-center rounded border border-border px-2 text-xs font-medium text-muted-foreground hover:text-foreground transition-colors"
      >
        {otherLocale.toUpperCase()}
      </a>
      <button
        id="theme-toggle-landing"
        class="flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-foreground transition-colors"
        aria-label="Toggle theme"
      >
        <svg class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="h-4 w-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a href={lp("/login")} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
        {l("nav.signin")}
      </a>
      <a
        href={lp("/signup")}
        class="flex h-8 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        {l("nav.getStarted")}
      </a>
    </div>
  </nav>

  <main>
    {/* Hero */}
    <section class="mx-auto max-w-3xl px-6 pt-20 pb-16 text-center">
      <div class="mb-6 inline-flex items-center rounded-full border border-border px-3 py-1 text-xs text-muted-foreground">
        {l("hero.badge")}
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        {l("hero.title1")}<br />
        {l("hero.title2")}<br />
        <span class="text-primary">{l("hero.title3")}</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base text-muted-foreground leading-relaxed">
        {l("hero.subtitle")}
      </p>
      <div class="mt-8 flex items-center justify-center gap-3">
        <a
          href={lp("/signup")}
          class="flex h-9 items-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          {l("hero.cta")}
        </a>
        <a
          href="#modes"
          class="flex h-9 items-center rounded-md border border-border px-6 text-sm font-medium transition-colors hover:bg-accent"
        >
          {l("hero.secondary")}
        </a>
      </div>

      {/* Stats */}
      <div class="mt-16 grid grid-cols-2 gap-6 sm:grid-cols-4">
        {([
          ["5", l("stats.modes")],
          ["11", l("stats.patches")],
          ["732", l("stats.tests")],
          ["10ms", l("stats.latency")],
        ] as const).map(([value, label]) => (
          <div>
            <p class="text-2xl font-semibold tracking-tight text-foreground">{value}</p>
            <p class="mt-1 text-xs text-muted-foreground">{label}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Modes Section */}
    <section id="modes" class="border-t border-border">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h2 class="text-center text-2xl font-semibold tracking-tight">{l("modes.title")}</h2>
        <p class="mx-auto mt-3 max-w-lg text-center text-sm text-muted-foreground">{l("modes.subtitle")}</p>

        <div class="mt-12 space-y-3">
          {([
            ["modes.http.name", "modes.http.latency", "modes.http.desc", "bg-chart-2"],
            ["modes.headless.name", "modes.headless.latency", "modes.headless.desc", "bg-chart-1"],
            ["modes.stealth.name", "modes.stealth.latency", "modes.stealth.desc", "bg-chart-3"],
            ["modes.human.name", "modes.human.latency", "modes.human.desc", "bg-chart-5"],
            ["modes.auto.name", "modes.auto.latency", "modes.auto.desc", "bg-chart-4"],
          ] as const).map(([nameKey, latencyKey, descKey, dotColor]) => (
            <div class="flex items-start gap-4 rounded-lg border border-border p-5 hover:bg-muted/30 transition-colors">
              <span class={`mt-1.5 h-2 w-2 shrink-0 rounded-full ${dotColor}`} />
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <h3 class="text-sm font-semibold text-foreground">{l(nameKey)}</h3>
                  <span class="rounded bg-muted px-1.5 py-0.5 text-xs text-muted-foreground">{l(latencyKey)}</span>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">{l(descKey)}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Features Grid */}
    <section id="features" class="border-t border-border">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h2 class="text-center text-2xl font-semibold tracking-tight">{l("features.title")}</h2>
        <p class="mx-auto mt-3 max-w-lg text-center text-sm text-muted-foreground">{l("features.subtitle")}</p>

        <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {([
            ["features.tls.title", "features.tls.desc"],
            ["features.h2.title", "features.h2.desc"],
            ["features.stealth.title", "features.stealth.desc"],
            ["features.behavioral.title", "features.behavioral.desc"],
            ["features.profiles.title", "features.profiles.desc"],
            ["features.auto.title", "features.auto.desc"],
            ["features.captcha.title", "features.captcha.desc"],
            ["features.proxy.title", "features.proxy.desc"],
            ["features.extraction.title", "features.extraction.desc"],
            ["features.actions.title", "features.actions.desc"],
            ["features.fleet.title", "features.fleet.desc"],
            ["features.mcp.title", "features.mcp.desc"],
          ] as const).map(([titleKey, descKey]) => (
            <div class="rounded-lg border border-border p-5">
              <h3 class="text-sm font-semibold text-foreground">{l(titleKey)}</h3>
              <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{l(descKey)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Production Ready */}
    <section class="border-t border-border">
      <div class="mx-auto max-w-4xl px-6 py-20">
        <h2 class="text-center text-2xl font-semibold tracking-tight">{l("tech.title")}</h2>
        <p class="mx-auto mt-3 max-w-lg text-center text-sm text-muted-foreground">{l("tech.subtitle")}</p>

        <div class="mt-12 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {([
            l("tech.tests"),
            l("tech.typescript"),
            l("tech.ci"),
            l("tech.metrics"),
            l("tech.docker"),
            l("tech.logging"),
          ]).map((item) => (
            <div class="flex items-start gap-3 rounded-lg border border-border p-4">
              <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-success" />
              <p class="text-sm text-foreground">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Pricing */}
    <section class="border-t border-border">
      <div class="mx-auto max-w-4xl px-6 py-20">
        <h2 class="text-center text-2xl font-semibold tracking-tight">{l("pricing.title")}</h2>
        <p class="mx-auto mt-3 max-w-lg text-center text-sm text-muted-foreground">{l("pricing.subtitle")}</p>

        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
          <div class="rounded-lg border border-border p-6">
            <p class="text-sm font-medium text-muted-foreground">{l("pricing.free")}</p>
            <p class="mt-2 text-3xl font-semibold tracking-tight">{l("pricing.free.price")}</p>
            <p class="mt-1 text-xs text-muted-foreground">{l("pricing.free.period")}</p>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground">
              <li>500 {l("pricing.requests")}</li>
              <li>3 {l("pricing.scrapers")}</li>
              <li>1 {l("pricing.concurrent")}</li>
            </ul>
            <a href={lp("/signup")} class="mt-6 flex h-8 items-center justify-center rounded-md border border-border text-sm font-medium transition-colors hover:bg-accent">
              {l("pricing.free.cta")}
            </a>
          </div>
          <div class="rounded-lg border-2 border-primary p-6">
            <div class="flex items-center gap-2">
              <p class="text-sm font-medium text-primary">{l("pricing.pro")}</p>
              <span class="rounded bg-primary/10 px-1.5 py-0.5 text-xs font-medium text-primary">{l("pricing.pro.popular")}</span>
            </div>
            <p class="mt-2 text-3xl font-semibold tracking-tight">{l("pricing.pro.price")}</p>
            <p class="mt-1 text-xs text-muted-foreground">{l("pricing.pro.period")}</p>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground">
              <li>10,000 {l("pricing.requests")}</li>
              <li>25 {l("pricing.scrapers")}</li>
              <li>5 {l("pricing.concurrents")}</li>
            </ul>
            <a href={`${lp("/signup")}?plan=pro`} class="mt-6 flex h-8 items-center justify-center rounded-md bg-primary text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
              {l("pricing.pro.cta")}
            </a>
          </div>
          <div class="rounded-lg border border-border p-6">
            <p class="text-sm font-medium text-muted-foreground">{l("pricing.enterprise")}</p>
            <p class="mt-2 text-3xl font-semibold tracking-tight">{l("pricing.enterprise.price")}</p>
            <p class="mt-1 text-xs text-muted-foreground">{l("pricing.enterprise.period")}</p>
            <ul class="mt-6 space-y-2 text-sm text-muted-foreground">
              <li>100,000 {l("pricing.requests")}</li>
              <li>{l("pricing.unlimited")}</li>
              <li>20 {l("pricing.concurrents")}</li>
            </ul>
            <a href={`${lp("/signup")}?plan=enterprise`} class="mt-6 flex h-8 items-center justify-center rounded-md border border-border text-sm font-medium transition-colors hover:bg-accent">
              {l("pricing.enterprise.cta")}
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-border">
      <div class="mx-auto max-w-4xl px-6 py-8">
        <div class="flex items-center justify-between">
          <span class="text-xs text-muted-foreground">&copy; 2024 PhantomRelay. {l("footer.rights")}</span>
          <div class="flex gap-4 text-xs text-muted-foreground">
            <a href={lp("/terms")} class="hover:text-foreground transition-colors">{l("footer.terms")}</a>
            <a href={lp("/privacy")} class="hover:text-foreground transition-colors">{l("footer.privacy")}</a>
            <a href={lp("/dashboard/api-docs")} class="hover:text-foreground transition-colors">API</a>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <script is:inline>
    document.getElementById("theme-toggle-landing")?.addEventListener("click", () => {
      document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
    });
  </script>
</BaseLayout>
