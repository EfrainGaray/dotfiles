---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@/i18n/translations";
import "@/styles/globals.css";

const locale = getLocaleFromUrl(Astro.url);
const isEs = locale === "es";
---

<BaseLayout title={isEs ? "Error del servidor" : "Server Error"}>
  <div class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
    <p class="text-7xl font-bold tracking-tight text-destructive/30">500</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">
      {isEs ? "Error interno del servidor" : "Internal server error"}
    </h1>
    <p class="mt-2 text-sm text-muted-foreground max-w-md">
      {isEs
        ? "Algo salió mal de nuestro lado. Nuestro equipo fue notificado. Intenta de nuevo en unos momentos."
        : "Something went wrong on our end. Our team has been notified. Please try again in a few moments."}
    </p>
    <div class="mt-6 flex gap-3">
      <button
        onclick="window.location.reload()"
        class="flex h-8 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        {isEs ? "Reintentar" : "Try again"}
      </button>
      <a
        href={isEs ? "/es/" : "/"}
        class="flex h-8 items-center rounded-md border border-border px-4 text-sm font-medium transition-colors hover:bg-accent"
      >
        {isEs ? "Ir al inicio" : "Go home"}
      </a>
    </div>
  </div>
</BaseLayout>
