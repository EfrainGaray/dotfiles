---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "@/i18n/translations";
import "@/styles/globals.css";

const locale = "es" as const;
const l = (key: Parameters<typeof t>[1]) => t(locale, key);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title="Registro">
  <div class="flex min-h-screen">
    <div class="hidden w-1/2 flex-col justify-between bg-sidebar p-12 lg:flex">
      <div>
        <span class="text-lg font-semibold tracking-tight">
          Phantom<span class="text-primary">Relay</span>
        </span>
      </div>
      <div>
        <p class="text-2xl font-semibold leading-tight tracking-tight text-foreground">
          {l("brand.signupTagline1")}<br />{l("brand.signupTagline2")}<br />{l("brand.signupTagline3")}
        </p>
        <p class="mt-4 text-sm text-muted-foreground">{l("brand.signupTaglineSub")}</p>
      </div>
      <p class="text-xs text-muted-foreground">&copy; 2024 PhantomRelay. {l("footer.rights")}</p>
    </div>

    <div class="flex w-full items-center justify-center px-6 lg:w-1/2">
      <div class="w-full max-w-sm space-y-6">
        <div class="flex items-center justify-between lg:hidden mb-8">
          <span class="text-lg font-semibold tracking-tight">
            Phantom<span class="text-primary">Relay</span>
          </span>
        </div>
        <div class="flex justify-end">
          <a href="/signup" class="flex h-7 items-center rounded border border-border px-2 text-xs font-medium text-muted-foreground hover:text-foreground transition-colors">EN</a>
        </div>

        <div>
          <h1 class="text-2xl font-semibold tracking-tight">{l("auth.createAccount")}</h1>
          <p class="mt-1 text-sm text-muted-foreground">{l("auth.signupSubtitle")}</p>
        </div>

        <form class="space-y-4" action="/api/auth/signup" method="POST">
          <div class="space-y-1.5">
            <label for="name" class="text-sm font-medium text-foreground">{l("auth.name")}</label>
            <input id="name" name="name" type="text" placeholder={l("auth.namePlaceholder")} required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1.5 text-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </div>
          <div class="space-y-1.5">
            <label for="email" class="text-sm font-medium text-foreground">{l("auth.email")}</label>
            <input id="email" name="email" type="email" placeholder="tu@ejemplo.com" required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1.5 text-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </div>
          <div class="space-y-1.5">
            <label for="password" class="text-sm font-medium text-foreground">{l("auth.password")}</label>
            <input id="password" name="password" type="password" placeholder={l("auth.createPassword")} required minlength="8" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1.5 text-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            <p class="text-xs text-muted-foreground">{l("auth.minChars")}</p>
          </div>
          <div class="flex items-start gap-2">
            <input id="terms" name="terms" type="checkbox" required class="mt-1 h-3.5 w-3.5 rounded border-input" />
            <label for="terms" class="text-xs text-muted-foreground">
              {l("auth.terms")} <a href={lp("/terms")} class="text-primary hover:underline">{l("auth.termsLink")}</a> {l("auth.and")} <a href={lp("/privacy")} class="text-primary hover:underline">{l("auth.privacyLink")}</a>
            </label>
          </div>
          <button type="submit" class="flex h-9 w-full items-center justify-center rounded-md bg-primary text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
            {l("auth.createBtn")}
          </button>
        </form>

        <div class="relative">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-border"></div></div>
          <div class="relative flex justify-center text-xs"><span class="bg-background px-2 text-muted-foreground">{l("auth.orContinue")}</span></div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <button class="flex h-9 items-center justify-center gap-2 rounded-md border border-border text-sm font-medium transition-colors hover:bg-accent">
            <svg class="h-4 w-4" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
          <button class="flex h-9 items-center justify-center gap-2 rounded-md border border-border text-sm font-medium transition-colors hover:bg-accent">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </button>
        </div>

        <p class="text-center text-sm text-muted-foreground">
          {l("auth.hasAccount")} <a href={lp("/login")} class="text-primary hover:underline">{l("auth.signin")}</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
