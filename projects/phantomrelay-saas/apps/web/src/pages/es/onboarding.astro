---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/globals.css";
---

<BaseLayout title="Bienvenido">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-lg space-y-8 text-center">
      <div>
        <span class="text-lg font-semibold tracking-tight">
          Phantom<span class="text-primary">Relay</span>
        </span>
      </div>

      <div>
        <h1 class="text-3xl font-bold tracking-tight">Bienvenido a PhantomRelay</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Comienza con tu primer scraper en menos de 2 minutos.
        </p>
      </div>

      <div class="space-y-3 text-left">
        <div class="rounded-lg border-2 border-primary bg-primary/5 p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-semibold text-primary-foreground">1</span>
            <h3 class="text-sm font-semibold text-foreground">Crea tu primer scraper</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            Usa el asistente visual para configurar objetivo, modo de evasión, extracción y programación — sin código.
          </p>
          <a
            href="/es/dashboard/scrapers/new"
            class="mt-3 ml-9 inline-flex h-8 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            Iniciar Asistente
          </a>
        </div>

        <div class="rounded-lg border border-border p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-medium text-muted-foreground">2</span>
            <h3 class="text-sm font-medium text-muted-foreground">Scraping rápido vía API</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            ¿Ya tienes tu clave API? Llama a <code class="rounded bg-muted px-1 py-0.5 text-xs">POST /scrape</code> directamente.
          </p>
        </div>

        <div class="rounded-lg border border-border p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-medium text-muted-foreground">3</span>
            <h3 class="text-sm font-medium text-muted-foreground">Configura notificaciones</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            Configura alertas por correo, webhooks o Slack para recibir notificaciones de tus ejecuciones.
          </p>
        </div>
      </div>

      <div class="flex items-center justify-between pt-4">
        <a href="/es/dashboard" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          Ir al dashboard
        </a>
        <div class="flex gap-1.5">
          <span class="h-1.5 w-6 rounded-full bg-primary"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-muted"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-muted"></span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
