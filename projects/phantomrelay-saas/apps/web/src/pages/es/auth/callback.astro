---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/globals.css";
---

<BaseLayout title="Autenticando...">
  <div class="flex min-h-screen items-center justify-center">
    <div class="text-center space-y-4">
      <div class="flex justify-center">
        <svg class="h-8 w-8 animate-spin text-primary" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
        </svg>
      </div>
      <p class="text-sm text-muted-foreground">Completando inicio de sesion...</p>
    </div>
  </div>

  <script>
    const TOKEN_KEY = "auth-token";

    const params = new URLSearchParams(window.location.search);
    const token = params.get("token");

    if (token) {
      localStorage.setItem(TOKEN_KEY, token);
      document.cookie = `${TOKEN_KEY}=${token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax`;
      window.location.href = "/es/dashboard";
    } else {
      window.location.href = "/es/login?error=oauth_failed";
    }
  </script>
</BaseLayout>
