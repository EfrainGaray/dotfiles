---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@/i18n/translations";
import "@/styles/globals.css";

const locale = getLocaleFromUrl(Astro.url);
const isEs = locale === "es";
---

<BaseLayout title={isEs ? "Mantenimiento" : "Maintenance"}>
  <div class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
    <span class="text-lg font-semibold tracking-tight">
      Phantom<span class="text-primary">Relay</span>
    </span>
    <div class="mt-8 rounded-lg border border-border bg-card p-8 max-w-md">
      <p class="text-5xl font-bold tracking-tight text-muted-foreground/30">⚙</p>
      <h1 class="mt-4 text-2xl font-semibold tracking-tight">
        {isEs ? "En mantenimiento" : "Under maintenance"}
      </h1>
      <p class="mt-2 text-sm text-muted-foreground">
        {isEs
          ? "Estamos realizando mejoras programadas. El servicio estará disponible en breve. Tus scrapers programados se reanudarán automáticamente."
          : "We're performing scheduled improvements. The service will be back shortly. Your scheduled scrapers will resume automatically."}
      </p>
      <div class="mt-6 space-y-2 text-left">
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-warning animate-pulse"></span>
          <span class="text-xs text-muted-foreground">{isEs ? "API: Mantenimiento" : "API: Maintenance"}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-warning animate-pulse"></span>
          <span class="text-xs text-muted-foreground">{isEs ? "Dashboard: Mantenimiento" : "Dashboard: Maintenance"}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-success"></span>
          <span class="text-xs text-muted-foreground">{isEs ? "Scrapers programados: En pausa" : "Scheduled scrapers: Paused"}</span>
        </div>
      </div>
    </div>
    <p class="mt-6 text-xs text-muted-foreground">
      {isEs ? "Tiempo estimado: menos de 30 minutos" : "Estimated time: less than 30 minutes"}
    </p>
  </div>
</BaseLayout>
