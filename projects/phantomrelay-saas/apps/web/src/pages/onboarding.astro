---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/globals.css";
---

<BaseLayout title="Welcome">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-lg space-y-8 text-center">
      <div>
        <span class="text-lg font-semibold tracking-tight">
          Phantom<span class="text-primary">Relay</span>
        </span>
      </div>

      <div>
        <h1 class="text-3xl font-bold tracking-tight">Welcome to PhantomRelay</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Let's get you started with your first scraper in under 2 minutes.
        </p>
      </div>

      <div class="space-y-3 text-left">
        <div class="rounded-lg border-2 border-primary bg-primary/5 p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-semibold text-primary-foreground">1</span>
            <h3 class="text-sm font-semibold text-foreground">Create your first scraper</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            Use the visual wizard to configure target, evasion mode, extraction, and schedule — no code needed.
          </p>
          <a
            href="/dashboard/scrapers/new"
            class="mt-3 ml-9 inline-flex h-8 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            Launch Wizard
          </a>
        </div>

        <div class="rounded-lg border border-border p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-medium text-muted-foreground">2</span>
            <h3 class="text-sm font-medium text-muted-foreground">Quick scrape via API</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            Already have your API key? Hit <code class="rounded bg-muted px-1 py-0.5 text-xs">POST /scrape</code> directly.
          </p>
        </div>

        <div class="rounded-lg border border-border p-5">
          <div class="flex items-center gap-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-medium text-muted-foreground">3</span>
            <h3 class="text-sm font-medium text-muted-foreground">Set up notifications</h3>
          </div>
          <p class="mt-2 ml-9 text-sm text-muted-foreground">
            Configure email alerts, webhooks, or Slack to get notified on run events.
          </p>
        </div>
      </div>

      <div class="flex items-center justify-between pt-4">
        <a href="/dashboard" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          Skip to dashboard
        </a>
        <div class="flex gap-1.5">
          <span class="h-1.5 w-6 rounded-full bg-primary"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-muted"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-muted"></span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
