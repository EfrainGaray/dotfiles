---
import BaseLayout from "./BaseLayout.astro";
import { getLocaleFromUrl } from "@/i18n/translations";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocaleFromUrl(Astro.url);
---

<BaseLayout title={title}>
  <div class="flex h-screen flex-col md:flex-row overflow-hidden" id="dashboard-root" data-path={currentPath} data-locale={locale}>
    <div id="sidebar-mount">
      <!-- React sidebar mounts here (includes mobile top bar + desktop sidebar) -->
    </div>
    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 md:px-8 md:py-8">
        <slot />
      </div>
    </main>
  </div>

  <script>
    import { createElement } from "react";
    import { createRoot } from "react-dom/client";
    import { Sidebar } from "../components/sidebar";

    const mount = document.getElementById("sidebar-mount");
    const root = document.getElementById("dashboard-root");
    if (mount && root) {
      const path = root.dataset.path || "/dashboard";
      const locale = (root.dataset.locale || "en") as "en" | "es";
      createRoot(mount).render(createElement(Sidebar, { currentPath: path, locale }));
    }
  </script>
</BaseLayout>
